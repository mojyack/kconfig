git clone --depth=1 -b rpi-6.12.y https://github.com/raspberrypi/linux/
pushd linux

## print firmware
curl 'https://732852.bugs.gentoo.org/attachment.cgi?id=649432' | patch -p1

# see ../regular-update for source setup

kmake Image.gz && kmake modules && kmake dtbs && rkmake modules_install

doas cp $W/arch/arm64/boot/Image.gz $D/boot/kernel_2712.img
doas cp $W/arch/arm64/boot/dts/broadcom/bcm2712-rpi-5-b.dtb $D/boot
doas mkdir -p $D/boot/overlays
doas cp -r $W/arch/arm64/boot/dts/overlays/*.dtbo $D/boot/overlays
