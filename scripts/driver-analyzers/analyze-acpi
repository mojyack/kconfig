}


def table_signature(path):
    name = os.path.basename(path)
    # SSDTn / dynamic files keep the signature in their first 4 bytes too.
    try:
        sig = open(path, "rb").read(4).decode("ascii", errors="replace")
    except OSError:
        sig = name[:4]
    # Some files like 'SSDT1' have a numeric suffix in name; trust file content.
    if sig.strip() and all(32 < ord(c) < 127 for c in sig):
        return sig
    return name[:4]


def iter_table_files(root):
    for cwd, dirs, files in os.walk(root):
        for f in files:
            yield os.path.join(cwd, f)


# ---------- Driver indexing ----------

# Find acpi_device_id arrays in a .c file and extract their HID strings.
ACPI_ID_ARRAY = re.compile(
    r"struct\s+acpi_device_id\s+\w+\s*\[\s*\]\s*=\s*\{(.*?)\}\s*;",
    re.DOTALL,
)
HID_LITERAL = re.compile(r'"([A-Z0-9@]{6,9})"')


def extract_acpi_ids_from_source(path):
    try:
        src = open(path, encoding="utf-8", errors="ignore").read()
    except OSError:
        return []
    ids = []
    for body in ACPI_ID_ARRAY.findall(src):
        for m in HID_LITERAL.findall(body):
            ids.append(m)
    return ids


# ---------- Main ----------

if len(sys.argv) < 3:
    print(
        "usage: analyze-acpi /path/to/linux /path/to/acpi/tables (/path/to/reference/config)",
    )
    sys.exit(1)

src = sys.argv[1]
tables_dir = sys.argv[2]
ref = sys.argv[3] if len(sys.argv) >= 4 else None

if not os.path.exists(acpi_cache_file):
    print("enumerating acpi drivers")
    drivers = walk_sources(
        [f"{src}/drivers", f"{src}/sound"], extract_acpi_ids_from_source
    )
    dump_cache(drivers, acpi_cache_file)
else:
    print("using cache")
    drivers = load_cache(acpi_cache_file)

# Collect HIDs from AML tables and signatures from all tables.
found_ids = {}  # id -> set(source table file)
found_sigs = {}  # sig -> set(source table file)
for path in iter_table_files(tables_dir):
    if not os.path.isfile(path):
        continue
    try:
        data = open(path, "rb").read()
    except OSError:
        continue
    sig = table_signature(path)
    found_sigs.setdefault(sig, set()).add(path)
    if sig == "DSDT" or sig == "SSDT":
        for hid in scan_aml_for_ids(data):
            found_ids.setdefault(hid, set()).add(path)

reference_config = load_config(ref) if ref is not None else {}
config_status = make_config_status(reference_config)

# Build reverse index: hid -> list of driver files.
hid_to_files = {}
for entry in drivers:
    path = entry[0]
    for hid in entry[1:]:
        hid_to_files.setdefault(hid, []).append(path)

matched = []  # (hid, [files])
missing = []
for hid in sorted(found_ids):
    files = hid_to_files.get(hid, [])
    if files:
        matched.append((hid, files))
    else:
        missing.append(hid)

print(f"acpi tables found ({len(found_sigs)}):")
for sig in sorted(found_sigs):
    desc = KNOWN_TABLES.get(sig, "")
    n = len(found_sigs[sig])
    suffix = f" x{n}" if n > 1 else ""
    print(f"    {sig}{suffix}  {desc}")

print(f"\nacpi ids without driver ({len(missing)}):")
for hid in missing:
    print(f"    {hid}")

print(f"\nmatched acpi ids ({len(matched)}):")
for hid, files in matched:
    print(f"    {hid}")
    for file in files:
        rel = file[len(src) + 1 :] if file.startswith(src) else file
        print(f"        {rel}")
        code, configs = find_corresponding_config(file)
        print_config_result(code, configs, config_status)
