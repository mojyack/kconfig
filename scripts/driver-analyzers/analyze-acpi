#!/usr/bin/env python3

import sys
import os
import re
import struct

from common import (
    walk_sources,
    dump_cache,
    load_cache,
    find_corresponding_config,
    load_config,
    make_config_status,
    print_config_result,
)

acpi_cache_file = "acpi-drivers-cache.txt"

# ---------- AML scanning ----------


# Decode the 4-byte compressed EISA PnP ID encoding used by AML.
def decode_eisaid(data):
    if len(data) < 4:
        return None
    b0, b1, b2, b3 = data[0], data[1], data[2], data[3]
    c1 = (b0 >> 2) & 0x1F
    c2 = ((b0 & 0x03) << 3) | ((b1 >> 5) & 0x07)
    c3 = b1 & 0x1F
    for c in (c1, c2, c3):
        if c < 1 or c > 26:
            return None
    return "%c%c%c%02X%02X" % (
        ord("A") - 1 + c1,
        ord("A") - 1 + c2,
        ord("A") - 1 + c3,
        b2,
        b3,
    )


def read_aml_string(data, off):
    end = data.find(b"\x00", off)
    if end < 0:
        return None
    try:
        s = data[off:end].decode("ascii")
    except UnicodeDecodeError:
        return None
    if not s:
        return None
    return s


# Decode an AML data object starting at `off`. Returns (value-or-None, new_off).
def decode_data_object(data, off):
    if off >= len(data):
        return (None, off)
    op = data[off]
    if op == 0x0D:  # StringPrefix
        s = read_aml_string(data, off + 1)
        if s is None:
            return (None, off + 1)
        return (s, off + 1 + len(s) + 1)
    if op == 0x0C:  # DWordPrefix
        if off + 5 > len(data):
            return (None, off + 1)
        eid = decode_eisaid(data[off + 1 : off + 5])
        return (eid, off + 5)
    if op == 0x0B:  # WordPrefix
        if off + 3 > len(data):
            return (None, off + 1)
        v = struct.unpack_from("<H", data, off + 1)[0]
        # zero-extended EISA id
        eid = decode_eisaid(struct.pack("<I", v))
        return (eid, off + 3)
    if op == 0x0A:  # BytePrefix
        return (None, off + 2)
    return (None, off + 1)


# Scan an AML blob for _HID and _CID values. Returns a set of strings.
def scan_aml_for_ids(data):
    ids = set()
    for tag in (b"_HID", b"_CID"):
        pos = 0
        while True:
            idx = data.find(tag, pos)
            if idx < 0:
                break
            pos = idx + 4
            # The byte immediately after the NameString is the data prefix.
            after = idx + 4
            if after >= len(data):
                continue
            op = data[after]
            if op == 0x12:  # PackageOp – only used by _CID with multiple entries
                # Skip PkgLength then iterate elements.
                pkg_off = after + 1
                pkg_len, hdr_len = read_pkg_length(data, pkg_off)
                if pkg_len is None:
                    continue
                cur = pkg_off + hdr_len
                end = pkg_off + pkg_len
                # NumElements byte
                if cur >= end:
                    continue
                cur += 1
                while cur < end and cur < len(data):
                    val, cur2 = decode_data_object(data, cur)
                    if val:
                        ids.add(val)
                    if cur2 <= cur:
                        break
                    cur = cur2
            else:
                val, _ = decode_data_object(data, after)
                if val:
                    ids.add(val)
    return ids


def read_pkg_length(data, off):
    if off >= len(data):
        return (None, 0)
    lead = data[off]
    nbytes = (lead >> 6) & 0x3
    if nbytes == 0:
        return (lead & 0x3F, 1)
    if off + 1 + nbytes > len(data):
        return (None, 0)
    val = lead & 0x0F
    for i in range(nbytes):
        val |= data[off + 1 + i] << (4 + 8 * i)
    return (val, 1 + nbytes)


# ---------- Table enumeration ----------

# Map fixed table signature -> rough description / typical Linux driver.
# Not exhaustive; used to surface non-DSDT tables in the report.
KNOWN_TABLES = {
    "APIC": "MADT — local/IO APIC",
    "HPET": "HPET timer",
    "MCFG": "PCIe ECAM",
    "FACP": "FADT — fixed hardware",
    "FACS": "FACS — firmware ctrl",
    "DSDT": "DSDT — differentiated AML",
    "SSDT": "SSDT — secondary AML",
    "BGRT": "Boot graphics",
    "FPDT": "Firmware perf data",
    "FIDT": "Firmware ID",
    "IVRS": "AMD-Vi IOMMU",
    "DMAR": "Intel VT-d IOMMU",
    "TPM2": "TPM 2.0",
    "TCPA": "TPM 1.2",
    "UEFI": "UEFI vendor data",
    "VFCT": "AMD VBIOS",
    "CRAT": "AMD component resource affinity",
    "CDIT": "AMD component distance",
    "SRAT": "NUMA affinity",
    "SLIT": "NUMA distance",
    "PCCT": "Platform comm channel",
    "PPTT": "Processor properties",
    "GTDT": "ARM generic timer",
